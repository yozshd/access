---
export const prerender = true;

// Astro
import { getCollection, render } from "astro:content";

// Layout
import Docs from "../../layouts/Docs.astro";

// Data
import { docPageTitle, getDocEntry } from "../../lib/doc-entry";

export async function getStaticPaths() {
	const [docs, readme] = await Promise.all([
		getCollection("docs"),
		getCollection("readme"),
	]);

	return [...docs, ...readme].map((entry) => ({
		params: { slug: entry.id },
	}));
}

const slug = Astro.params.slug ?? "";

const entry = slug ? await getDocEntry(slug) : undefined;
if (!entry) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const title = docPageTitle(entry);
const { Content } = await render(entry);
---

<Docs
	title={title}
	description={entry.data.description}
	docSlug={slug}
	frontmatter={entry.data}
>
	<Content />
</Docs>
