---
import { getCollection } from "astro:content";
import {
	buildContentTree,
	findNodeAtPath,
	flattenContentTreeForDisplay,
	partitionRootNodes,
} from "../lib/content-tree";
import { sitePath } from "../lib/site-paths";
import ContentTreeNode from "./ContentTreeNode.astro";

interface Props {
	dirPath?: string;
	rootLabel?: string;
	repoUrl?: string;
	rootNavHref?: string;
	headerPath?: string;
}

const {
	dirPath = "",
	rootLabel = "@yozshd/access",
	repoUrl = "https://github.com/yozshd/access",
	rootNavHref = repoUrl,
	headerPath = sitePath(""),
} = Astro.props;

const entries = await getCollection("docs");
const tree = buildContentTree(entries);
const scopeNode = findNodeAtPath(tree, dirPath);
const lines = scopeNode
	? flattenContentTreeForDisplay(partitionRootNodes(scopeNode.children), {
			includeReadme: dirPath === "",
		})
	: [];

/** Chrome-bar URL — the path users actually browse, not the GitHub repo. */
const headerDisplayUrl = new URL(headerPath, Astro.site ?? Astro.url).href;
---

<nav class="w-full max-w-2xl text-left" aria-label="Documentation">
	{
		lines.length > 0 ? (
			<div class="overflow-hidden rounded-xl border border-gray-200 bg-gray-50 shadow-sm ring-1 ring-gray-900/5">
				<div
					class="flex items-center gap-2 border-b border-gray-200 bg-gray-100/80 px-4 pt-3 pb-2"
					aria-hidden="true"
				>
					<span class="font-mono text-xs text-gray-500">{headerDisplayUrl}</span>
				</div>
				<div class="overflow-x-auto px-4 py-4 font-mono text-sm leading-6 text-gray-800">
					<a
						href={rootNavHref}
						class="text-indigo-600 hover:text-indigo-500 hover:underline"
						target={rootNavHref === repoUrl ? "_blank" : undefined}
						rel={rootNavHref === repoUrl ? "noopener noreferrer" : undefined}
					>
						{rootLabel}
					</a>
					{lines.map((line) => (
						<ContentTreeNode
							prefix={line.prefix}
							label={line.label}
							href={line.href}
						/>
					))}
				</div>
			</div>
		) : (
			<p class="text-sm text-gray-500">No documentation yet.</p>
		)
	}
</nav>
